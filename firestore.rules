rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-all Gate
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUser(data) {
      return data.xp is int
          && data.xp >= 0
          && data.maxXp is int
          && data.maxXp > 0
          && data.level is int
          && data.level >= 1
          && data.levelName is string
          && data.levelName.size() <= 200
          && data.credits is int
          && data.credits >= 0
          && data.currentStreak is int
          && data.currentStreak >= 0
          && data.maxStreak is int
          && data.maxStreak >= 0
          && data.totalCompleted is int
          && data.totalCompleted >= 0
          && data.totalXpGained is int
          && data.totalXpGained >= 0
          && data.playerHp is int
          && data.playerHp >= 0
          && data.maxPlayerHp is int
          && data.maxPlayerHp >= 0
          && data.doubleXp is bool;
    }

    function isValidHabit(data) {
      return data.id is string
          && data.id.size() <= 128
          && data.number is int
          && data.name is string
          && data.name.size() <= 200
          && data.category is string
          && data.category.size() <= 100
          && data.xpReward is int
          && data.xpReward >= 0
          && data.creditsReward is int
          && data.creditsReward >= 0
          && data.completedToday is bool
          && data.streakCount is int
          && data.streakCount >= 0
          && data.iconName is string
          && data.iconName.size() <= 100;
    }

    // User Profile matching
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().keys().hasAll(['xp', 'maxXp', 'level', 'levelName', 'credits', 'currentStreak', 'maxStreak', 'totalCompleted', 'totalXpGained', 'playerHp', 'maxPlayerHp', 'doubleXp']);
                    
      allow update: if isOwner(userId)
                    && isValidUser(incoming());

      // Habits sub-collection inside User scope
      match /habits/{habitId} {
        allow read: if isOwner(userId);
        
        allow create, update: if isOwner(userId)
                             && isValidId(habitId)
                             && isValidHabit(incoming())
                             && incoming().keys().hasAll(['id', 'number', 'name', 'category', 'xpReward', 'creditsReward', 'completedToday', 'streakCount', 'iconName'])
                             && incoming().keys().size() == 9;
                             
        allow delete: if isOwner(userId);
      }
    }
  }
}
